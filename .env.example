# Postgres connection string
DATABASE_URL=postgres://localhost:5432/curiomancer

# Public URL of your Curiomancer instance
ORIGIN=http://localhost:5173

# Random secret for session signing — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme

# Apple MapKit JS — from developer.apple.com
APPLE_TEAM_ID=
MAPKIT_KEY_ID=
MAPKIT_KEY_PATH=secrets/AuthKey_XXXXXXXXXX.p8

# Comma-separated emails that get role='admin' on signup (and skip invite check)
ADMIN_EMAILS=
