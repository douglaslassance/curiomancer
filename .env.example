# Postgres connection string
DATABASE_URL=postgres://localhost:5432/curiomancer

# Public URL of your Curiomancer instance
ORIGIN=http://localhost:5173

# Random secret for session signing — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme

# Apple MapKit JS — from developer.apple.com
APPLE_TEAM_ID=
MAPKIT_KEY_ID=
# Local dev: path to the downloaded .p8 private key (gitignored).
MAPKIT_KEY_PATH=secrets/AuthKey_XXXXXXXXXX.p8
# Production: the .p8 file is never shipped in the container image, so supply
# the key via env. Preferred: base64 (no newline issues across secret stores):
#   base64 -i secrets/AuthKey_XXXXXXXXXX.p8
# MAPKIT_PRIVATE_KEY_BASE64=
# Alternatively, the raw PEM contents (real newlines, or escaped as \n):
# MAPKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Cloudflare Email Service - enables real email delivery. When absent, emails
# are logged to the console instead of sent, which is fine for local/test builds.
# API token needs the "Email Sending: Edit" permission.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Verified sender, e.g. "Curiomancer <no-reply@mail.curiomancer.com>".
EMAIL_FROM=

# Cloudflare R2 (S3-compatible) - avatar storage (src/lib/server/storage.ts).
# Create an R2 API token scoped to the bucket below at dash.cloudflare.com/r2/api-tokens.
# When any of these four are unset, avatars are written to local disk instead
# (under STORAGE_DIR, default "storage/avatars"), which is fine for local dev.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# STORAGE_DIR=storage/avatars

# PostHog analytics (optional) - leave PUBLIC_POSTHOG_PROJECT_TOKEN unset to
# disable entirely. Token is from PostHog project settings. Must be present at
# build time (baked in via $env/static/public), not just at runtime.
PUBLIC_POSTHOG_PROJECT_TOKEN=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking (optional) - leave PUBLIC_SENTRY_DSN unset to disable
# entirely. DSN is from Sentry project settings > Client Keys. Must be present
# at build time (baked in via $env/static/public), not just at runtime.
PUBLIC_SENTRY_DSN=
# Needed only to upload source maps during `pnpm build` for readable stack
# traces. Auth token needs "project:releases" + "org:read" scopes, from
# Sentry Settings > Auth Tokens. Also build-time only.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Stripe billing (optional) - leave STRIPE_SECRET_KEY unset to disable checkout
# entirely. All three are runtime, server-only secrets (never build-time).
# - STRIPE_SECRET_KEY: use a test key (sk_test_...) in dev, from Stripe >
#   Developers > API keys. Switch to a live key (sk_live_...) for production.
# - STRIPE_PRICE_ID: the recurring "Curiomancer Pro" price (price_...).
# - STRIPE_WEBHOOK_SECRET: signing secret (whsec_...) from `stripe listen`
#   (local) or a dashboard webhook endpoint (prod), used to verify events.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
