# Postgres connection string
DATABASE_URL=postgres://localhost:5432/curiomancer

# Public URL of your Curiomancer instance
ORIGIN=http://localhost:5173

# Random secret for session signing — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme

# Apple MapKit JS — from developer.apple.com
APPLE_TEAM_ID=
MAPKIT_KEY_ID=
# Local dev: path to the downloaded .p8 private key (gitignored).
MAPKIT_KEY_PATH=secrets/AuthKey_XXXXXXXXXX.p8
# Production: the .p8 file is never shipped in the container image, so supply
# the key via env. Preferred: base64 (no newline issues across secret stores):
#   base64 -i secrets/AuthKey_XXXXXXXXXX.p8
# MAPKIT_PRIVATE_KEY_BASE64=
# Alternatively, the raw PEM contents (real newlines, or escaped as \n):
# MAPKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Resend - enables real email delivery. When absent, emails are logged to the
# console instead of sent, which is fine for local/test builds.
RESEND_API_KEY=
# Verified sender, e.g. "Curiomancer <no-reply@mail.curiomancer.com>".
EMAIL_FROM=
